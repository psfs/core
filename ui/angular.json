{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "psfs-ui": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "psfs",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "index": {
              "input": "src/index.html",
              "output": "index.html"
            },
            "outputPath": {
              "base": "../src/public/ui",
              "browser": ""
            },
            "assets": [
              "src/favicon.svg"
            ],
            "styles": [
              "src/styles.css"
            ]
          },
          "configurations": {
            "development": {
              "optimization": false,
              "outputHashing": "none",
              "sourceMap": true
            },
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                }
              ],
              "outputHashing": "all"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "allowedHosts": [
              "ui"
            ]
          },
          "configurations": {
            "production": {
              "buildTarget": "psfs-ui:build:production"
            },
            "development": {
              "buildTarget": "psfs-ui:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
